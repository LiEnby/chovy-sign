<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:Settings="clr-namespace:ChovySign_GUI.Settings"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="ChovySign_GUI.Settings.SettingsTab">
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="1*"/>
			<ColumnDefinition Width="10*"/>
			<ColumnDefinition Width="1*"/>
		</Grid.ColumnDefinitions>
		<Grid Grid.Column="1">
			<Grid.RowDefinitions>
				<RowDefinition Height="1*"/>
				<RowDefinition Height="1*"/>
				<RowDefinition Height="1*"/>
				<RowDefinition Height="1*"/>
				<RowDefinition Height="1*"/>
				<RowDefinition Height="1*"/>
				<RowDefinition Height="1*"/>
			</Grid.RowDefinitions>

			
			<Settings:ConfigToggle Name="packagePsvimg" 
								 ConfigKey="USE_CMA_PSVIMG" 
								 Label="Use Content Manager (Package to PSVIMG)" 
								 Default="true"
								 HorizontalAlignment="Stretch"
								 Grid.Row="0"/>
			<Settings:ConfigToggle Name="downloadCovers" 
								 ConfigKey="USE_COVER_DOWNLOADER" 
								 Label="Auto-Download PS1 Game Covers" 
								 Default="true"
								 HorizontalAlignment="Stretch"
								 Grid.Row="1"/>
			<Settings:ConfigU64 Name="cmaAccountId" 
								 ConfigKey="USE_ACCOUNT_ID"
								 Label="CMA Account ID:"
								 HorizontalAlignment="Stretch" 
								 Grid.Row="2"/>
			<Settings:ConfigPath Name="cmaDirectory" 
								 ConfigKey="USE_CMA_DIRECTORY"
								 IsDirectory="true"
								 Label="Output Folder:"
								 HorizontalAlignment="Stretch"
								 Grid.Row="3"/>
			<Settings:ConfigDropDown Name="libCryptMode"
								 ConfigKey="USE_LIBCRYPT_METHOD"
								 Label="LibCrypt Method:"
								 HorizontalAlignment="Stretch"
								 Grid.Row="4"/>
			<Settings:ConfigDropDown Name="atrac3Encoder"
								 ConfigKey="USE_ATRAC_TOOL"
								 Label="Atrac3 Encoder:"
								 HorizontalAlignment="Stretch"
								 Grid.Row="5"/>
			<Settings:ConfigDropDown Name="streamType"
								ConfigKey="USE_STREAM_TYPE"
								Label="Build Stream Type:"
								HorizontalAlignment="Stretch"
								Grid.Row="6"/>

		</Grid>
	</Grid>
	
</UserControl>
